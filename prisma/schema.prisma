generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int               @id @default(autoincrement())
  username            String            @unique
  password            String
  name                String
  role                String
  createdAt           DateTime          @default(now())
  displayId           Int?
  eventAssignments    EventAssignment[]
  teacherHalaqas      Halaqa[]          @relation("TeacherHalaqas")
  notifications       Notification[]
  assistantHalaqas    Halaqa[]          @relation("AssistantTeachers")
  participatingEvents QuranicEvent[]    @relation("EventTeachers")
  khayrukumCertificates KhayrukumCertificate[] @relation("TeacherCertificates")

  @@index([role])
}

model Halaqa {
  id            Int       @id @default(autoincrement())
  name          String
  teacherId     Int?
  createdAt     DateTime  @default(now())
  pointsEnabled Boolean   @default(true)
  logo          String?
  teacher       User?     @relation("TeacherHalaqas", fields: [teacherId], references: [id])
  holidays      Holiday[]
  students      Student[]
  assistants    User[]    @relation("AssistantTeachers")
  families      Family[]

  @@index([teacherId])
}

model Student {
  id                 Int               @id @default(autoincrement())
  name               String
  username           String            @unique
  password           String
  hifzProgress       String?
  currentHifzSurahId Int?              @default(114)
  juzCount           Float             @default(0)
  reviewPlan         String?
  dailyTargetPages   Float?            @default(1.0)
  createdAt          DateTime          @default(now())
  halaqaId           Int?
  displayId          Int?
  joinDate           DateTime?         @default(now())
  nationalId         String?
  parentPhone        String?
  phone              String?
  studentNotes       String?
  updatedAt          DateTime          @default(now()) @updatedAt
  parentPhone2       String?
  nationality        String?
  feeStatusSummer    String?           @default("PENDING")
  feeStatusTerm1     String?           @default("PENDING")
  feeStatusTerm2     String?           @default("PENDING")
  currentHifzAyah    Int?              @default(1)
  attendance         Attendance[]
  eventAssignments   EventAssignment[]
  exams              Exam[]
  notifications      Notification[]
  points             Point[]
  sessions           Session[]
  familyId           Int?
  family             Family?           @relation(fields: [familyId], references: [id])
  halaqa             Halaqa?           @relation(fields: [halaqaId], references: [id])
  StudyPlanEntry     StudyPlanEntry[]
  khayrukumCertificates KhayrukumCertificate[]

  @@index([halaqaId])
  @@index([halaqaId, juzCount])
}

model Point {
  id        Int      @id @default(autoincrement())
  studentId Int
  amount    Int
  reason    String
  category  String
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([category])
}

model Attendance {
  id        Int      @id @default(autoincrement())
  studentId Int
  date      DateTime @default(now())
  status    String
  student   Student  @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([date])
}

model Session {
  id                     Int           @id @default(autoincrement())
  studentId              Int
  date                   DateTime      @default(now())
  hifzSurah              String?
  hifzFromPage           Int?
  hifzToPage             Int?
  hifzFromAyah           Int?
  hifzToAyah             Int?
  murajaahFromSurah      String?
  murajaahFromAyah       Int?
  murajaahToSurah        String?
  murajaahToAyah         Int?
  pagesCount             Float?
  resultString           String?
  notes                  String?
  errorsCount            Int           @default(0)
  alertsCount            Int           @default(0)
  cleanPagesCount        Float         @default(0)
  isGoalAchieved         Boolean       @default(false)
  quranicEventId         Int?
  hifzAlerts             Int           @default(0)
  hifzErrors             Int           @default(0)
  hifzCleanPages         Float         @default(0)
  minorMurajaahFromAyah  Int?
  minorMurajaahFromSurah String?
  minorMurajaahToAyah    Int?
  minorMurajaahToSurah   String?
  minorAlertsCount       Int           @default(0)
  minorCleanPagesCount   Float         @default(0)
  minorErrorsCount       Int           @default(0)
  hifzToSurah            String?
  hifzSurahEvaluations   Json?
  isFinishedSurah        Boolean       @default(false)
  quranicEvent           QuranicEvent? @relation(fields: [quranicEventId], references: [id])
  student                Student       @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([date])
  @@index([studentId, date])
  @@index([date, pagesCount])
}

model QuranicEvent {
  id               Int               @id @default(autoincrement())
  name             String
  startDate        DateTime
  endDate          DateTime
  isActive         Boolean           @default(false)
  createdAt        DateTime          @default(now())
  allowOpenTesting Boolean           @default(false)
  assignments      EventAssignment[]
  sessions         Session[]
  teachers         User[]            @relation("EventTeachers")
}

model EventAssignment {
  id        Int          @id @default(autoincrement())
  eventId   Int
  teacherId Int
  studentId Int
  event     QuranicEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  student   Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher   User         @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([eventId, teacherId, studentId])
  @@index([studentId])
  @@index([teacherId])
}

model Notification {
  id             Int      @id @default(autoincrement())
  title          String   @default("إشعار جديد")
  message        String
  type           String   @default("INFO")
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())
  attachmentUrl  String?
  attachmentType String?
  userId         Int?
  studentId      Int?
  senderId       Int?
  senderRole     String?
  student        Student? @relation(fields: [studentId], references: [id])
  user           User?    @relation(fields: [userId], references: [id])

  @@index([studentId])
  @@index([userId])
}

model Exam {
  id          Int       @id @default(autoincrement())
  studentId   Int
  stationId   Int?
  stationName String
  status      String
  examDate    DateTime?
  examTime    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  grade       Float?
  notes       String?
  student     Student   @relation(fields: [studentId], references: [id])

  @@index([studentId])
}

model Holiday {
  id        Int      @id @default(autoincrement())
  name      String
  startDate DateTime
  endDate   DateTime
  createdAt DateTime @default(now())
  halaqaId  Int?
  halaqa    Halaqa?  @relation(fields: [halaqaId], references: [id])

  @@index([halaqaId])
}

model StudyPlanEntry {
  id          Int       @id @default(autoincrement())
  studentId   Int
  date        DateTime
  type        String
  surahId     Int
  fromAyah    Int
  toAyah      Int
  isCompleted Boolean   @default(false)
  actualDate  DateTime?
  sessionId   Int?
  toSurahId   Int?
  Student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([date])
}

model KhayrukumCertificate {
  id           Int      @id @default(autoincrement())
  studentId    Int
  teacherId    Int?
  title        String?
  branchNumber Int
  examType     String   @default("حضوري")
  examDate     DateTime
  grade        Float
  fileUrl      String
  createdAt    DateTime @default(now())

  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher      User?    @relation("TeacherCertificates", fields: [teacherId], references: [id], onDelete: SetNull)

  @@index([studentId])
  @@index([teacherId])
}

model Family {
  id        Int       @id @default(autoincrement())
  name      String
  halaqaId  Int?
  halaqa    Halaqa?   @relation(fields: [halaqaId], references: [id])
  students  Student[]
  createdAt DateTime  @default(now())

  @@index([halaqaId])
}

